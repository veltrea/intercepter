{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veltrea Interceptor",
  "version": "0.1.0",
  "identifier": "com.user.veltrea-interceptor",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Veltrea Interceptor",
        "width": 1200,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src ws://localhost:* ws://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
